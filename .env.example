# ==========================================================================
# Navix Route Intelligence — variáveis de ambiente (exemplo)
# Copie para .env e ajuste. NUNCA comite o .env real (ver docs/security.md).
# ==========================================================================

# --- Ambiente ---
NODE_ENV=development

# --- API (backend NestJS) ---
API_PORT=3001
API_GLOBAL_PREFIX=api
CORS_ORIGINS=http://localhost:3000

# --- Banco de dados (via PgBouncer) ---
DB_HOST=localhost
DB_PORT=6432
# Owner/superusuário — usado por migrações e seed (bypassa RLS).
DB_USER=navix
DB_PASSWORD=navix_dev_password
# Role de RUNTIME da aplicação — NÃO superusuário, sujeito à RLS.
# Criado automaticamente pela migração CreateAppRole.
DB_APP_USER=navix_app
# OBRIGATÓRIO em produção: esta senha de exemplo é rejeitada no boot (ADR-0052).
DB_APP_PASSWORD=navix_app_password
DB_NAME=navix
# OBRIGATÓRIO "true" em produção (ADR-0052).
DB_SSL=false

# Conexão direta ao Postgres (usada por migrações — bypassa o pooler)
DB_DIRECT_PORT=5432

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# --- Autenticação (ver docs/security.md) ---
# Access token: JWT RS256 (assimétrico). Em desenvolvimento, se as chaves abaixo
# não forem definidas, um par RSA efêmero é gerado no boot (você só precisa
# refazer login após reiniciar). Em produção, forneça as chaves via secret manager.
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=1209600
# OBRIGATÓRIAS em produção — sem elas cada instância assina com um par efêmero
# próprio e rejeita os tokens das demais. O boot falha se faltarem (ADR-0052).
# JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
# JWT_KEY_ID=key-2026-07
# Rotação (opcional): chave pública anterior, mantida para verificar tokens em voo.
# JWT_PREVIOUS_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
# JWT_PREVIOUS_KEY_ID=key-2026-06

# --- Criptografia (envelope encryption — placeholder de desenvolvimento) ---
# Em produção, a KEK vem do KMS e as DEKs são por tenant (ADR-0010).
ENCRYPTION_KEK=change-me-32-bytes-base64-key-dev

# --- Object storage (mídia do Proof of Delivery — ADR-0019) ---
# Imagens/assinaturas do POD são gravadas fora do Postgres; o banco guarda só a URL.
# driver=local grava em disco (dev) e serve via /api/v1/files. driver=s3 usa qualquer
# provedor compatível com S3 (AWS S3, Cloudflare R2, Google Cloud Storage via S3 API).
STORAGE_DRIVER=local
STORAGE_LOCAL_DIR=./storage
STORAGE_PUBLIC_BASE_URL=http://localhost:3001/api/v1/files
# Assinatura das URLs de mídia (ADR-0046): segredo estável entre instâncias.
# Se vazio, usa um segredo por-processo (ok em dev single-instance).
# OBRIGATÓRIO em produção — o boot falha se faltar (ADR-0052).
# MEDIA_URL_SECRET=troque-por-um-segredo-forte
MEDIA_URL_TTL_SECONDS=900
# Retenção do histórico de posições (dias). 0 desliga o expurgo (ADR-0048).
TRACKING_RETENTION_DAYS=90
# --- S3/R2/GCS (obrigatório quando STORAGE_DRIVER=s3) ---
# S3_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com   # AWS: deixe vazio; GCS: https://storage.googleapis.com
# S3_REGION=auto                 # AWS: us-east-1; R2: auto
# S3_BUCKET=navix-pod
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_PUBLIC_BASE_URL=https://cdn.suaempresa.com   # base pública/CDN de onde as URLs são servidas
# S3_FORCE_PATH_STYLE=true       # R2/MinIO: true; AWS S3: false

# --- Observabilidade (ADR-0021, ver docs/observability.md) ---
# Métricas Prometheus ficam sempre expostas em /metrics (fora do prefixo /api).
METRICS_ENABLED=true
# Tracing distribuído (OpenTelemetry) é OPT-IN: precisa de um coletor OTLP.
# Desligado (default), é no-op total — nenhuma instrumentação, nada muda.
OTEL_ENABLED=false
OTEL_SERVICE_NAME=navix-api
# Endpoint OTLP/HTTP do coletor (ex.: Jaeger all-in-one do compose de observabilidade).
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# OTEL_DEBUG=false               # loga o diagnóstico interno do OTel no console

# --- Otimização / reotimização (ADR-0023) ---
# Reotimização automática ao criar/editar/cancelar entregas. Opt-in (default off):
# quando true, o Optimizer reage a eventos do Delivery e reenfileira jobs (debounced).
OPTIMIZER_AUTO_REOPTIMIZE=false
OPTIMIZER_REOPTIMIZE_DEBOUNCE_MS=2000
# Fila de jobs de otimização (ADR-0007/0055). `inprocess` (default): processa no
# mesmo processo (não durável). `bullmq`: fila durável no Redis, com worker,
# retry/backoff e redelivery em crash.
OPTIMIZER_QUEUE_DRIVER=inprocess
# Ativa o worker BullMQ neste processo (default true, co-locado com a API). Para
# um worker dedicado: rode a API com `false` (só enfileira) e o processo
# `npm run start:worker` com `true`.
OPTIMIZER_WORKER_ENABLED=true
OPTIMIZER_JOB_ATTEMPTS=3
OPTIMIZER_JOB_BACKOFF_MS=1000
# Zonas de risco (ADR-0024): JSON de círculos que penalizam paradas dentro deles.
# Default [] (sem efeito). Ex.: [{"latitude":-23.55,"longitude":-46.63,"radiusKm":2,"penalty":5}]
OPTIMIZER_RISK_ZONES=[]

# --- Provedor de mapas/roteamento (ADR-0027) ---
# haversine (default, geométrico) ou mapbox (distância+duração real via Matrix API).
# Com mapbox, defina MAPBOX_TOKEN; qualquer falha externa cai em Haversine.
MAPS_PROVIDER=haversine
# MAPBOX_TOKEN=pk.xxxxxxxx   # token do backend (segredo; não commitar)

# --- Frontend (Next.js) ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001/api
WEB_PORT=3000
# Token público do Mapbox para o mapa do otimizador (crie um grátis em
# https://account.mapbox.com/access-tokens/). Sem ele, o mapa mostra um fallback
# com a sequência de paradas. Deve ficar em apps/web/.env.local para o Next ler.
# NEXT_PUBLIC_MAPBOX_TOKEN=pk.xxxxxxxx
