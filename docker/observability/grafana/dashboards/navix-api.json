{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "schemaVersion": 39,
  "title": "Navix API — Visão geral",
  "tags": ["navix"],
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "15s",
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "title": "Requisições por segundo (por rota)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "navix-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "navix-prometheus" },
          "expr": "sum by (route) (rate(http_server_requests_total[5m]))",
          "legendFormat": "{{route}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "Latência HTTP p95 (s)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "navix-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "navix-prometheus" },
          "expr": "histogram_quantile(0.95, sum by (le, route) (rate(http_server_request_duration_seconds_bucket[5m])))",
          "legendFormat": "{{route}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "Taxa de erro 5xx (%)",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "navix-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "percent" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "navix-prometheus" },
          "expr": "100 * sum(rate(http_server_requests_total{status_code=~\"5..\"}[5m])) / clamp_min(sum(rate(http_server_requests_total[5m])), 1)",
          "legendFormat": "5xx %"
        }
      ]
    },
    {
      "id": 4,
      "title": "Memória residente do processo (bytes)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "navix-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "navix-prometheus" },
          "expr": "process_resident_memory_bytes{service=\"navix-api\"}",
          "legendFormat": "RSS"
        }
      ]
    }
  ]
}
