# Dependencies
node_modules/
.pnp
.pnp.js

# Build output
dist/
build/
.next/
out/
*.tsbuildinfo

# Environment
.env
.env.local
.env.*.local
!.env.example

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Coverage / tests
coverage/
.nyc_output/

# Editor / OS
.idea/
.vscode/*
!.vscode/extensions.json
.DS_Store
Thumbs.db

# Docker volumes (local)
docker/volumes/

# Object storage (driver local de desenvolvimento) — apenas a saída em runtime,
# ancorada na raiz (NÃO o código em src/**/storage/).
/storage/
/apps/api/storage/

# Terraform — cache de providers, state e variáveis reais nunca vão ao git.
# O .terraform.lock.hcl É versionado (garante os mesmos providers) — não ignorar.
**/.terraform/*
*.tfstate
*.tfstate.*
*.tfplan
crash.log
crash.*.log
# terraform.tfvars carrega valores reais (segredos/IDs); só o .example é versionado.
infra/terraform/terraform.tfvars
*.auto.tfvars
